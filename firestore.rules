rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         request.auth.token.email == 'admin@gmail.com');
    }

    // User Profiles
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && isAdmin();

      // Sub-collections for history
      match /donations/{donationId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      match /intakes/{intakeId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Blood Requests
    match /requests/{requestId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        resource.data.patientId == request.auth.uid || 
        resource.data.donorId == request.auth.uid ||
        resource.data.status in ['pending', 'accepted', 'completed'] // Broaden slightly for fetching stats
      );
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        isAdmin() || 
        resource.data.patientId == request.auth.uid || 
        resource.data.donorId == request.auth.uid
      );

      // Messages within requests
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          isAdmin() || 
          get(/databases/$(database)/documents/requests/$(requestId)).data.patientId == request.auth.uid || 
          get(/databases/$(database)/documents/requests/$(requestId)).data.donorId == request.auth.uid
        );
      }
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
