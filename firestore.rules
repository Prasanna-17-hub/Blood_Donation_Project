rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      // Allow all authenticated users to read and list profiles (needed for search and dashboards)
      allow read, list: if request.auth != null;
      
      // Allow any authenticated user to create/update profiles to avoid role-based permission issues
      // This "removes the role of admin" by allowing all authorized actions to any logged-in user
      allow create, update, delete: if request.auth != null;

      // Sub-collections
      match /donations/{donationId} {
        allow read, write: if request.auth != null;
      }
      match /intakes/{intakeId} {
        allow read, write: if request.auth != null;
      }
    }

    // Blood Requests
    match /requests/{requestId} {
      // Any authenticated user can manage requests
      allow read, list, create, update, delete: if request.auth != null;

      // Messages within requests
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
